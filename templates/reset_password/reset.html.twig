{% extends 'base.html.twig' %}

{% block title %}Redefinir senha — Project Core{% endblock %}

{% block body %}
<div class="flex justify-center items-start pt-12">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <h1 class="text-2xl font-bold text-slate-800 mb-1">Redefinir senha</h1>
        <p class="text-sm text-slate-500 mb-6">Escolha uma nova senha segura para sua conta.</p>

        {{ form_start(resetForm, {attr: {class: 'space-y-4'}}) }}
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1" for="{{ resetForm.plainPassword.first.vars.id }}">
                    Nova senha
                </label>
                {{ form_widget(resetForm.plainPassword.first, {attr: {class: 'w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition', autofocus: true, placeholder: 'Mínimo 8 caracteres'}}) }}
                <div class="text-xs text-red-600 mt-1">{{ form_errors(resetForm.plainPassword.first) }}</div>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1" for="{{ resetForm.plainPassword.second.vars.id }}">
                    Confirmar senha
                </label>
                {{ form_widget(resetForm.plainPassword.second, {attr: {class: 'w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition', placeholder: 'Repita a senha'}}) }}
                <div class="text-xs text-red-600 mt-1">{{ form_errors(resetForm.plainPassword.second) }}</div>
            </div>

            <div class="text-xs text-red-600">{{ form_errors(resetForm.plainPassword) }}</div>

            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 rounded-lg transition-colors text-sm">
                Salvar nova senha
            </button>
        {{ form_end(resetForm) }}
    </div>
</div>
{% endblock %}
