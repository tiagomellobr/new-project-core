{% extends 'base.html.twig' %}

{% block title %}Meu Perfil — Project Core{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto space-y-6">
    <h1 class="text-2xl font-bold text-slate-800">Meu Perfil</h1>

    {# Dados Pessoais #}
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <h2 class="text-lg font-semibold text-slate-700 mb-6">Dados Pessoais</h2>

        {{ form_start(profileForm, {action: path('app_profile'), attr: {class: 'space-y-4'}}) }}
            {{ form_errors(profileForm) }}

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1" for="{{ profileForm.name.vars.id }}">
                    Nome completo
                </label>
                {{ form_widget(profileForm.name, {attr: {class: 'w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition'}}) }}
                {{ form_errors(profileForm.name) }}
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1" for="{{ profileForm.email.vars.id }}">
                    E-mail
                </label>
                {{ form_widget(profileForm.email, {attr: {class: 'w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition'}}) }}
                {{ form_errors(profileForm.email) }}
            </div>

            <div class="pt-2">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-lg transition-colors text-sm">
                    Salvar alterações
                </button>
            </div>
        {{ form_end(profileForm) }}
    </div>

    {# Alterar Senha #}
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <h2 class="text-lg font-semibold text-slate-700 mb-6">Alterar Senha</h2>

        {{ form_start(passwordForm, {action: path('app_profile_password'), attr: {class: 'space-y-4'}}) }}
            {{ form_errors(passwordForm) }}

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1" for="{{ passwordForm.currentPassword.vars.id }}">
                    Senha atual
                </label>
                {{ form_widget(passwordForm.currentPassword, {attr: {class: 'w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition'}}) }}
                {{ form_errors(passwordForm.currentPassword) }}
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1" for="{{ passwordForm.newPassword.first.vars.id }}">
                    Nova senha
                </label>
                {{ form_widget(passwordForm.newPassword.first, {attr: {class: 'w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition'}}) }}
                {{ form_errors(passwordForm.newPassword.first) }}
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1" for="{{ passwordForm.newPassword.second.vars.id }}">
                    Confirmar nova senha
                </label>
                {{ form_widget(passwordForm.newPassword.second, {attr: {class: 'w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition'}}) }}
                {{ form_errors(passwordForm.newPassword) }}
            </div>

            <div class="pt-2">
                <button type="submit" class="bg-slate-700 hover:bg-slate-800 text-white font-semibold px-6 py-2.5 rounded-lg transition-colors text-sm">
                    Alterar senha
                </button>
            </div>
        {{ form_end(passwordForm) }}
    </div>
</div>
{% endblock %}
