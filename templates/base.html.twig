<!DOCTYPE html>
<html lang="pt-BR">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Project Core{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🌊</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="min-h-screen bg-slate-50 text-slate-900">
        <nav class="bg-white border-b border-slate-200 shadow-sm">
            <div class="max-w-5xl mx-auto px-4 flex items-center justify-between h-16">
                <a href="/" class="flex items-center gap-2 font-bold text-lg text-blue-700">
                    🌊 Project Core
                </a>
                <div class="flex items-center gap-4 text-sm font-medium">
                    {% if app.user %}
                        <span class="text-slate-600">Olá, {{ app.user.name ?? app.user.email }}</span>
                        <a href="{{ path('app_profile') }}" class="text-slate-600 hover:text-blue-700 transition-colors">Meu Perfil</a>
                        <a href="{{ path('app_logout') }}" class="text-slate-500 hover:text-red-600 transition-colors">Sair</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="text-slate-600 hover:text-blue-700 transition-colors">Entrar</a>
                        {% if registration_enabled %}
                        <a href="{{ path('app_register') }}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg transition-colors">Cadastrar</a>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        </nav>

        <main class="max-w-5xl mx-auto px-4 py-8">
            {% for message in app.flashes('success') %}
                <div class="mb-4 p-4 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm">
                    {{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="mb-4 p-4 rounded-lg bg-red-50 border border-red-200 text-red-800 text-sm">
                    {{ message }}
                </div>
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        {# LGPD Cookie Consent Banner #}
        {# Set GOOGLE_ANALYTICS_ID in .env.local for production (e.g. G-XXXXXXXXXX) #}
        <div data-controller="cookie-consent"
             data-cookie-consent-ga-id-value="{% if app.environment == 'prod' %}{{ app.request.server.get('GOOGLE_ANALYTICS_ID') ?? '' }}{% endif %}">
            <div data-cookie-consent-target="banner"
                 class="hidden fixed bottom-0 inset-x-0 z-50 transition-all duration-300 ease-in-out p-4 pb-6">
                <div class="max-w-4xl mx-auto">
                    <div class="bg-white border border-slate-200 rounded-2xl shadow-xl p-5 flex flex-col sm:flex-row items-start sm:items-center gap-4">
                        <div class="flex-shrink-0 w-9 h-9 rounded-full bg-blue-50 flex items-center justify-center">
                            <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                            </svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-slate-800">Privacidade e cookies</p>
                            <p class="text-xs text-slate-500 mt-0.5 leading-relaxed">
                                Usamos cookies essenciais para o funcionamento da plataforma e, com seu consentimento,
                                cookies analíticos para melhorar a experiência. Seus dados são tratados conforme a
                                <a href="{{ path('app_privacy_policy') }}" class="text-blue-600 hover:underline font-medium">LGPD</a>.
                            </p>
                        </div>
                        <div class="flex items-center gap-2 flex-shrink-0 w-full sm:w-auto">
                            <button data-action="click->cookie-consent#decline"
                                    class="flex-1 sm:flex-none px-4 py-2 text-xs font-medium text-slate-500 bg-slate-100 hover:bg-slate-200 rounded-lg transition-colors">
                                Recusar opcionais
                            </button>
                            <button data-action="click->cookie-consent#accept"
                                    class="flex-1 sm:flex-none px-4 py-2 text-xs font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors">
                                Aceitar todos
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>
